{
  "ConnectionStrings": {
    "Deke": "Host=localhost;Database=deke;Username=deke;Password=deke"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Npgsql": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Embeddings": {
    "ModelPath": "models/all-MiniLM-L6-v2/model.onnx",
    "VocabPath": "models/all-MiniLM-L6-v2/vocab.txt"
  },
  "ApiKey": "",
  "AllowedHosts": "*",
  "Federation": {
    "Enabled": false,
    "InstanceId": "default",
    "MaxHops": 3,
    "TimeoutMs": 5000,
    "DelegationThreshold": 0.4,
    "LocalityWeights": {
      "Local": 1.0,
      "Hop1": 0.9,
      "Hop2": 0.75,
      "Hop3": 0.6
    },
    "Peers": []
  }
}
