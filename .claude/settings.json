{
  "permissions": {
    "deny": [
      "LSP",
      "DesignSync"
    ]
  },
  "deniedMcpServers": [
    { "serverName": "docker-mcp" },
    { "serverName": "DesignSync" },
    { "serverName": "sqlcl" },
    { "serverName": "windows-desktop" },
    { "serverName": "system-monitor" },
    { "serverName": "claude.ai Google Calendar" },
    { "serverName": "claude.ai Matrixify" },
    { "serverName": "claude.ai Mermaid Chart" },
    { "serverName": "claude.ai Google Drive" }
  ],
  "skillOverrides": {
    "graphify": "off",
    "smithery-ai-cli": "off",
    "qf-check": "off",
    "qf-complete": "off",
    "qf-decide": "off",
    "qf-migrate-to-raid": "off",
    "qf-new": "off",
    "qf-resume": "off",
    "qf-switch": "off",
    "verbose-basic": "off",
    "verbose-detailed": "off",
    "verbose-debug": "off",
    "verbose-off": "off",
    "verbose-status": "off",
    "dataviz": "off",
    "artifact-design": "off",
    "playwright-skill": "off",
    "playwright-skill:playwright-skill": "off"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$input | ConvertFrom-Json | ForEach-Object { $f = $_.tool_input.file_path; if ($f -like '*.cs') { dotnet format --include $f 2>&1 | Out-Null } }",
            "timeout": 30,
            "statusMessage": "Formatting .cs file..."
          }
        ]
      }
    ]
  }
}
